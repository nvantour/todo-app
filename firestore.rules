rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /todos/{todoId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == "ninovantour@hotmail.com";
    }
    match /categories/{categoryId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == "ninovantour@hotmail.com";
    }
  }
}
